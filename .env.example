# Security Configuration
# Copy this file to .env and update the values
# Flask Secret Key for sessions:
# Generate securely via: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///instance/renovation_credit.db
# Example for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/renovation_credit

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5001

# System Settings
HIGH_RISK_DISTRICTS=
MAX_DEBT_RATIO=0.7

# Email Notifications (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
